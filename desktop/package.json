{
  "name": "fisicahn-desktop",
  "productName": "FísicaHN",
  "desktopName": "FisicaHN.desktop",
  "version": "1.1.0",
  "description": "Simulador de física multiplataforma para laboratorios escolares (funciona aunque NetSupport bloquee el navegador).",
  "main": "main.js",
  "homepage": "https://github.com/escoto34/FisicaHN",
  "repository": {
    "type": "git",
    "url": "https://github.com/escoto34/FisicaHN.git"
  },
  "bugs": {
    "url": "https://github.com/escoto34/FisicaHN/issues"
  },
  "author": {
    "name": "FísicaHN",
    "email": "fisicahn@users.noreply.github.com"
  },
  "license": "MIT",
  "scripts": {
    "sync": "bash scripts/sync-app.sh",
    "start": "npm run sync && electron .",
    "pack": "npm run sync && electron-builder --dir",
    "dist": "npm run sync && electron-builder",
    "dist:win": "npm run sync && electron-builder --win portable nsis",
    "dist:linux": "npm run sync && electron-builder --linux AppImage deb",
    "dist:linux:appimage": "npm run sync && electron-builder --linux AppImage",
    "dist:mac": "npm run sync && electron-builder --mac dmg"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "hn.fisica.simulador",
    "productName": "FisicaHN",
    "copyright": "Copyright © FísicaHN",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "icon": "build/icon.png",
    "files": [
      "main.js",
      "preload.js",
      "app/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "main.js"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Education",
      "synopsis": "Simulador de física offline para colegios",
      "maintainer": "FísicaHN <fisicahn@users.noreply.github.com>",
      "vendor": "FísicaHN",
      "syncDesktopName": true,
      "desktop": {
        "entry": {
          "Name": "FísicaHN",
          "Comment": "Simulador de física offline para colegios",
          "Categories": "Education;Science;"
        }
      }
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "FisicaHN"
    },
    "portable": {
      "artifactName": "FisicaHN-Portable-${version}.exe"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.education",
      "identity": null
    }
  },
  "allowScripts": {
    "electron@43.1.0": true,
    "electron-winstaller@5.4.0": true
  }
}
